<?xml version="1.0" ?>
<!-- Minimal model so model://qr_wall resolves; geometry lives in world.sdf. -->
<sdf version="1.10">
  <model name="qr_wall">
    <static>true</static>
    <link name="link">
      <visual name="placeholder">
        <pose>0 0 -1000 0 0 0</pose>
        <geometry>
          <box>
            <size>0.01 0.01 0.01</size>
          </box>
        </geometry>
      </visual>
    </link>
  </model>
</sdf>
